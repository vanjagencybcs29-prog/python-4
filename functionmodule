# Function to print all factors of n
def factors(n):
    print(f"Factors of n:")
    for i in range(1, n + 1):
        if n % i == 0:  # Check if i divides n
            print(i, end=" ")
    print()  # New line

# Function to print all prime factors of n
def prime_factors(n):
    print(f"Prime factors of {n}:")
    i = 2
    while i <= n:
        while n % i == 0:  # If i divides n
            print(i, end=" ")
            n //= i  # Reduce n
        i += 1
    print()  # New line

# Example usage
num = int(input("Enter a number: "))
factors(num)
prime_factors(num)

